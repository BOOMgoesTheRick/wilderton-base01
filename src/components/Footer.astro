---
import type { Translations } from '../i18n/types';
import type { Locale } from '../i18n/utils';

interface Props {
  t: Translations;
  locale: Locale;
}

const { t, locale } = Astro.props;
const f = t.footer;
---

<footer>
  <div class="wrap foot">
    <div>
      <div class="brand">
        <span class="dot" aria-hidden="true"></span>WILDERTON&nbsp;/&nbsp;{t.nav.brand}
      </div>
      <p class="desc">{f.desc}</p>
    </div>
    <div>
      <h4>{f.nav_heading}</h4>
      <a href="#services">{f.links.services}</a>
      <a href="#about">{f.links.about}</a>
      <a href="#why">{t.nav.practice}</a>
      <a href="#portfolio">{t.nav.portfolio}</a>
      <a href="#diagnostic">{t.nav.diagnostic}</a>
      <a href="#contact">{f.links.contact}</a>
    </div>
    <div>
      <h4>{f.lang_heading}</h4>
      <a href="/en/" style={locale === 'en' ? 'font-weight:500' : 'opacity:.6'}>
        English{locale === 'en' ? ' — active' : ''}
      </a>
      <a href="/fr/" style={locale === 'fr' ? 'font-weight:500' : 'opacity:.6'}>
        Français{locale === 'fr' ? ' — actif' : ''}
      </a>
    </div>
    <div>
      <h4>{f.legal_heading}</h4>
      <a href={locale === 'fr' ? '/fr/confidentialite' : '/en/privacy'}>{f.privacy}</a>
      <a href="mailto:info@wilderton-advisory.com">info@wilderton-advisory.com</a>
    </div>
  </div>
  <div class="wrap foot-bottom">
    <span>{f.rights}</span>
    <span>QC · CAN · v.2026.05</span>
  </div>
</footer>
