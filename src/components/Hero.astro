---
import type { Translations } from '../i18n/types';
import type { Locale } from '../i18n/utils';

interface Props {
  t: Translations;
  locale: Locale;
}

const { t, locale } = Astro.props;
const h = t.hero;

const headlineLines = locale === 'en'
  ? ['Technology', 'Leadership for', 'Organizations']
  : ['Leadership', 'technologique pour', 'les organisations'];
---

<section class="hero" id="top">
  <div class="hero-honeycomb" id="honeycomb" aria-hidden="true"></div>
  <div class="wrap hero-grid">
    <div>
      <span class="eyebrow">{h.eyebrow}</span>
      <h1 class="display" aria-label={headlineLines.join(' ')}>
        {headlineLines.map((line) => (
          <span class="ln" data-text={line} aria-hidden="true"></span>
        ))}
      </h1>
      <p class="lede">{h.subheadline}</p>
      <div class="hero-cta">
        <a class="btn" href="#services">{h.cta_primary} <span class="arr">→</span></a>
        <a class="btn ghost" href="#contact">{h.cta_secondary} <span class="arr">→</span></a>
      </div>
    </div>

    <aside class="hero-meta">
      <div class="row"><span>v.2026.05</span><span class="ln"></span></div>
      <div class="row"><span>Québec · CA</span><span class="ln"></span></div>
      <div class="row"><span>Booking · Q3</span><span class="ln"></span></div>
      <div class="hero-coord" style="margin-top:24px">
        <span><b>46.81°N</b></span>
        <span><b>71.21°W</b></span>
      </div>
    </aside>
  </div>
</section>

<script>
  (function honeycomb() {
    const host = document.getElementById('honeycomb');
    if (!host) return;

    const size = 34;
    const w = Math.sqrt(3) * size;
    const vSpace = size * 1.5;
    const W = window.innerWidth;
    const H = 900;
    const cols = Math.ceil(W / w) + 2;
    const rows = Math.ceil(H / vSpace) + 2;

    const svgNS = 'http://www.w3.org/2000/svg';
    const svg = document.createElementNS(svgNS, 'svg');
    svg.setAttribute('viewBox', `0 0 ${W} ${H}`);
    svg.setAttribute('preserveAspectRatio', 'xMidYMid slice');

    function hexPath(cx: number, cy: number, r: number) {
      let d = '';
      for (let i = 0; i < 6; i++) {
        const a = (Math.PI / 3) * i + Math.PI / 6;
        const x = cx + r * Math.cos(a);
        const y = cy + r * Math.sin(a);
        d += (i === 0 ? 'M' : 'L') + x.toFixed(2) + ' ' + y.toFixed(2) + ' ';
      }
      return d + 'Z';
    }

    const cells: SVGPathElement[] = [];
    for (let r = 0; r < rows; r++) {
      for (let c = 0; c < cols; c++) {
        const cx = c * w + (r % 2 ? w / 2 : 0);
        const cy = r * vSpace;
        const p = document.createElementNS(svgNS, 'path');
        p.setAttribute('d', hexPath(cx, cy, size - 2));
        p.setAttribute('fill', 'none');
        p.setAttribute('stroke', 'currentColor');
        p.setAttribute('stroke-width', '0.6');
        p.setAttribute('opacity', '0.10');
        svg.appendChild(p);
        cells.push(p);
      }
    }
    host.appendChild(svg);

    if (window.matchMedia('(prefers-reduced-motion: no-preference)').matches) {
      function pulse() {
        const n = Math.max(2, Math.floor(cells.length * 0.012));
        for (let i = 0; i < n; i++) {
          const cell = cells[Math.floor(Math.random() * cells.length)];
          const roll = Math.random();
          const accent = roll < 0.18;
          const fillIt = !accent && roll < 0.45;
          cell.style.transition = 'opacity .8s ease, fill .8s ease, stroke .8s ease';
          cell.setAttribute('opacity', accent ? '0.9' : fillIt ? '0.16' : '0.32');
          if (accent) {
            const ac = getComputedStyle(document.documentElement).getPropertyValue('--accent').trim() || '#E5481A';
            cell.setAttribute('stroke', ac);
            cell.setAttribute('stroke-width', '1.2');
          } else if (fillIt) {
            cell.setAttribute('fill', 'currentColor');
          }
          setTimeout(() => {
            cell.setAttribute('opacity', '0.10');
            cell.setAttribute('fill', 'none');
            cell.setAttribute('stroke', 'currentColor');
            cell.setAttribute('stroke-width', '0.6');
          }, 900 + Math.random() * 1400);
        }
      }
      pulse();
      setInterval(pulse, 1100);

      svg.style.transition = 'transform .6s cubic-bezier(.2,.7,.2,1)';
      document.addEventListener('mousemove', (e) => {
        const x = (e.clientX / window.innerWidth - 0.5) * 14;
        const y = (e.clientY / window.innerHeight - 0.5) * 10;
        svg.style.transform = `translate3d(${x}px, ${y}px, 0)`;
      }, { passive: true });
    }
  })();

  (function typewriter() {
    const lines = document.querySelectorAll<HTMLElement>('.display .ln[data-text]');
    if (!lines.length) return;

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) {
      lines.forEach(ln => { ln.textContent = ln.dataset.text || ''; });
      return;
    }

    const cursor = document.createElement('span');
    cursor.className = 'type-cursor';
    cursor.setAttribute('aria-hidden', 'true');

    let lineIdx = 0;
    let charIdx = 0;

    function delay(): number {
      const r = Math.random();
      if (r < 0.06) return 240 + Math.random() * 160; // hesitation
      if (r < 0.20) return 85 + Math.random() * 65;   // slow key
      return 36 + Math.random() * 42;                  // normal
    }

    function type() {
      if (lineIdx >= lines.length) return;
      const ln = lines[lineIdx];
      const text = ln.dataset.text || '';
      if (!ln.contains(cursor)) ln.appendChild(cursor);
      if (charIdx < text.length) {
        ln.insertBefore(document.createTextNode(text[charIdx]), cursor);
        charIdx++;
        setTimeout(type, delay());
      } else {
        lineIdx++;
        charIdx = 0;
        setTimeout(type, 260 + Math.random() * 160);
      }
    }

    setTimeout(type, 320);
  })();
</script>
