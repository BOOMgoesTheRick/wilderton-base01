---
import type { Translations } from '../i18n/types';
import type { Locale } from '../i18n/utils';
import { getOtherLocale, getOtherLocaleLabel } from '../i18n/utils';

interface Props {
  t: Translations;
  locale: Locale;
}

const { t, locale } = Astro.props;
const otherLocale = getOtherLocale(locale);
const otherLabel = getOtherLocaleLabel(locale);
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500"
>
  <!-- Top gold accent line -->
  <div class="h-px bg-gradient-to-r from-transparent via-gold/70 to-transparent"></div>

  <div
    id="header-inner"
    class="flex items-center justify-between px-6 lg:px-12 py-5 transition-all duration-500"
  >
    <!-- Logo -->
    <a
      href={`/${locale}/`}
      class="flex items-center gap-3 group"
      aria-label="Wilderton Advisory — Home"
    >
      <!-- W Mark -->
      <div
        class="w-9 h-9 flex items-center justify-center border border-gold/60 group-hover:border-gold transition-colors duration-300"
      >
        <svg
          width="20"
          height="16"
          viewBox="0 0 20 16"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path
            d="M1 1L5.5 15L10 6L14.5 15L19 1"
            stroke="#C6A75E"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </div>

      <!-- Name -->
      <div class="leading-tight">
        <div
          class="font-display font-semibold text-sm tracking-wider text-cream/95 group-hover:text-cream transition-colors"
        >
          WILDERTON
        </div>
        <div class="font-body text-gold/80 text-[10px] tracking-[0.2em] uppercase">
          {locale === 'fr' ? 'Conseil' : 'Advisory'}
        </div>
      </div>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-10" aria-label="Main navigation">
      <a
        href={`/${locale}/#services`}
        class="text-cream/70 hover:text-gold text-sm font-body tracking-wide transition-colors duration-200"
      >
        {t.nav.services}
      </a>
      <a
        href={`/${locale}/#about`}
        class="text-cream/70 hover:text-gold text-sm font-body tracking-wide transition-colors duration-200"
      >
        {t.nav.about}
      </a>
      <a
        href={`/${locale}/#contact`}
        class="text-cream/70 hover:text-gold text-sm font-body tracking-wide transition-colors duration-200"
      >
        {t.nav.contact}
      </a>
    </nav>

    <!-- Right side actions -->
    <div class="hidden lg:flex items-center gap-5">
      <!-- Language switcher -->
      <a
        href={`/${otherLocale}/`}
        class="text-cream/50 hover:text-gold text-xs font-body font-semibold tracking-[0.18em] uppercase border border-cream/20 hover:border-gold/50 px-3 py-1.5 transition-all duration-200"
        aria-label={`Switch to ${otherLabel}`}
      >
        {otherLabel}
      </a>

      <!-- CTA -->
      <a href={`/${locale}/#contact`} class="btn-primary text-xs py-3 px-6">
        {t.nav.book}
        <svg
          class="w-3.5 h-3.5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"
          />
        </svg>
      </a>
    </div>

    <!-- Mobile menu button -->
    <div class="lg:hidden flex items-center gap-4">
      <a
        href={`/${otherLocale}/`}
        class="text-cream/50 hover:text-gold text-xs font-body font-semibold tracking-widest uppercase transition-colors"
      >
        {otherLabel}
      </a>
      <button
        id="mobile-menu-toggle"
        aria-label="Toggle menu"
        aria-expanded="false"
        class="flex flex-col gap-1.5 p-1 group"
      >
        <span
          class="w-6 h-px bg-cream/70 group-hover:bg-gold transition-all duration-300 origin-center"
          id="burger-top"></span>
        <span
          class="w-4 h-px bg-cream/70 group-hover:bg-gold transition-all duration-300"
          id="burger-mid"></span>
        <span
          class="w-6 h-px bg-cream/70 group-hover:bg-gold transition-all duration-300 origin-center"
          id="burger-bot"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu overlay -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden absolute top-full left-0 right-0 bg-navy-dark border-t border-gold/20 py-8 px-6"
  >
    <nav class="flex flex-col gap-6" aria-label="Mobile navigation">
      <a
        href={`/${locale}/#services`}
        class="text-cream/80 hover:text-gold text-lg font-body tracking-wide transition-colors duration-200 mobile-nav-link"
      >
        {t.nav.services}
      </a>
      <a
        href={`/${locale}/#about`}
        class="text-cream/80 hover:text-gold text-lg font-body tracking-wide transition-colors duration-200 mobile-nav-link"
      >
        {t.nav.about}
      </a>
      <a
        href={`/${locale}/#contact`}
        class="text-cream/80 hover:text-gold text-lg font-body tracking-wide transition-colors duration-200 mobile-nav-link"
      >
        {t.nav.contact}
      </a>
      <div class="pt-4 border-t border-gold/20">
        <a href={`/${locale}/#contact`} class="btn-primary w-full justify-center">
          {t.nav.book}
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  // Header scroll behavior
  const header = document.getElementById('site-header');
  const headerInner = document.getElementById('header-inner');

  function updateHeader() {
    if (window.scrollY > 40) {
      header?.classList.add('bg-navy/95', 'backdrop-blur-md', 'shadow-lg', 'shadow-navy-dark/40');
      headerInner?.classList.replace('py-5', 'py-3');
    } else {
      header?.classList.remove('bg-navy/95', 'backdrop-blur-md', 'shadow-lg', 'shadow-navy-dark/40');
      headerInner?.classList.replace('py-3', 'py-5');
    }
  }

  updateHeader();
  window.addEventListener('scroll', updateHeader, { passive: true });

  // Mobile menu toggle
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden') === false;
    menu?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close mobile menu on link click
  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
