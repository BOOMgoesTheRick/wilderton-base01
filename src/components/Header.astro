---
import type { Translations } from '../i18n/types';
import type { Locale } from '../i18n/utils';
import { getOtherLocale, getOtherLocaleLabel } from '../i18n/utils';

interface Props {
  t: Translations;
  locale: Locale;
}

const { t, locale } = Astro.props;
const otherLocale = getOtherLocale(locale);
const otherLabel = getOtherLocaleLabel(locale);
const otherLocalePath = `/${otherLocale}/`;
---

<header class="nav">
  <div class="wrap nav-inner">
    <a href={`/${locale}/`} class="brand">
      <span class="mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <polygon points="12,2 22,7 22,17 12,22 2,17 2,7"></polygon>
          <polygon points="12,5 19,8.5 19,15.5 12,19 5,15.5 5,8.5" fill="currentColor" stroke="none"></polygon>
        </svg>
      </span>
      WILDERTON&nbsp;/&nbsp;Advisory
    </a>

    <nav class="nav-links" aria-label="Main navigation">
      <a href="#services">{t.nav.services}</a>
      <a href="#about">{t.nav.about}</a>
      <a href="#why">{t.nav.practice}</a>
      <a href="#portfolio">{t.nav.portfolio}</a>
      <a href="#contact">{t.nav.contact}</a>
    </nav>

    <div class="nav-right">
      <a class="lang" href={otherLocalePath} aria-label={`Switch to ${otherLabel}`}>
        {locale.toUpperCase()}&nbsp;·&nbsp;<span style="opacity:.4">{otherLabel}</span>
      </a>
      <div class="theme-toggle" role="group" aria-label="Color theme">
        <button id="th-lt" aria-pressed="true" title={t.nav.theme_light_label}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
          </svg>
          {t.nav.theme_light}
        </button>
        <button id="th-dk" aria-pressed="false" title={t.nav.theme_dark_label}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z"></path>
          </svg>
          {t.nav.theme_dark}
        </button>
      </div>
    </div>
  </div>
</header>

<script>
  (function theme() {
    const root = document.documentElement;
    const lt = document.getElementById('th-lt') as HTMLButtonElement | null;
    const dk = document.getElementById('th-dk') as HTMLButtonElement | null;
    if (!lt || !dk) return;

    function apply(mode: string) {
      if (mode === 'dark') {
        root.setAttribute('data-theme', 'dark');
        lt!.setAttribute('aria-pressed', 'false');
        dk!.setAttribute('aria-pressed', 'true');
      } else {
        root.removeAttribute('data-theme');
        lt!.setAttribute('aria-pressed', 'true');
        dk!.setAttribute('aria-pressed', 'false');
      }
      try {
        localStorage.setItem('wilderton-theme', mode);
        localStorage.setItem('wilderton-theme-exp', String(Date.now() + 5 * 86400 * 1000));
      } catch (_) {}
    }

    // Sync button state with theme already applied by the blocking inline script in <head>
    const current = root.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
    apply(current);

    lt.addEventListener('click', () => apply('light'));
    dk.addEventListener('click', () => apply('dark'));
  })();
</script>
