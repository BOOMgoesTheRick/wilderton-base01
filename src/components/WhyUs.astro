---
import type { Translations } from '../i18n/types';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const w = t.whyus;
---

<section class="sec" id="why">
  <div class="wrap">
    <div class="sec-head reveal">
      <div class="sec-tag">{w.eyebrow}</div>
      <div>
        <h2 class="sec-title">{w.headline}</h2>
      </div>
    </div>

    <div class="why-grid">
      {w.items.map((item, i) => (
        <div class="why reveal">
          <div class="ix">{w.labels[i]}</div>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
