---
import type { Translations } from '../i18n/types';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const w = t.whyus;

const icons = [
  // Executive Fluency - speech/communication
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>`,
  // Architecture First - blueprint/structure
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>`,
  // Boutique Accountability - user/person
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>`,
  // Compliance Ready - checkmark / badge
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>`,
];
---

<section class="bg-white py-24 lg:py-36">
  <div class="container mx-auto px-6 lg:px-16 xl:px-24">
    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-16 lg:mb-20 fade-up">
      <div class="section-eyebrow justify-center mb-5">
        <div class="w-8 h-px bg-gold" aria-hidden="true"></div>
        {w.eyebrow}
        <div class="w-8 h-px bg-gold" aria-hidden="true"></div>
      </div>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-navy leading-tight">
        {w.headline}
      </h2>
    </div>

    <!-- Differentiators grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-0 border border-navy/8">
      {
        w.items.map((item, i) => (
          <div
            class="fade-up group p-8 lg:p-10 border-b xl:border-b-0 border-r-0 xl:border-r border-navy/8 last:border-r-0 last:border-b-0 md:[&:nth-child(2)]:border-r-0 xl:[&:nth-child(2)]:border-r hover:bg-cream/60 transition-colors duration-300 relative"
            style={`transition-delay: ${i * 0.1}s`}
          >
            <!-- Gold top accent on hover -->
            <div class="absolute top-0 left-8 right-8 h-0.5 bg-gold scale-x-0 group-hover:scale-x-100 transition-transform duration-400 origin-left" aria-hidden="true" />

            <!-- Icon -->
            <div class="w-12 h-12 border border-navy/15 group-hover:border-gold/50 flex items-center justify-center mb-6 transition-colors duration-300">
              <svg
                class="w-5 h-5 text-navy/40 group-hover:text-gold transition-colors duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                aria-hidden="true"
                set:html={icons[i]}
              />
            </div>

            <h3 class="font-display text-xl font-semibold text-navy mb-4">
              {item.title}
            </h3>
            <p class="font-body text-navy/55 text-sm leading-relaxed">
              {item.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
