---
import type { Translations } from '../i18n/types';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const s = t.services;
---

<section class="sec" id="services">
  <div class="wrap">
    <div class="sec-head reveal">
      <div class="sec-tag">{s.eyebrow}</div>
      <div>
        <h2 class="sec-title">{s.headline}</h2>
        <p class="sec-sub">{s.subheadline}</p>
      </div>
    </div>

    <div id="services-list">
      {s.items.map((item, i) => (
        <article
          class="svc reveal"
          data-open="false"
          role="button"
          tabindex="0"
          aria-expanded="false"
        >
          <div class="svc-num">{item.number} /</div>
          <div>
            <h3 class="svc-title">{item.title}</h3>
            <p class="svc-desc">{item.description}</p>
          </div>
          <div></div>
          <div class="svc-tags">
            {item.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.svc').forEach((card) => {
    function toggle() {
      const isOpen = card.getAttribute('data-open') === 'true';
      document.querySelectorAll('.svc').forEach((c) => {
        c.setAttribute('data-open', 'false');
        c.setAttribute('aria-expanded', 'false');
      });
      const next = isOpen ? 'false' : 'true';
      card.setAttribute('data-open', next);
      card.setAttribute('aria-expanded', next);
    }
    card.addEventListener('click', toggle);
    card.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
        e.preventDefault();
        toggle();
      }
    });
  });
</script>
