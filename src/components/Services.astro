---
import type { Translations } from '../i18n/types';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const s = t.services;

// SVG icons for each service (24x24 viewBox, line-art style)
const icons = [
  // 01 IT Strategy
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>`,
  // 02 M365
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>`,
  // 03 Cybersecurity
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`,
  // 04 Endpoint
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>`,
  // 05 Infrastructure
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12H3m2 0a2 2 0 104 0M5 12a2 2 0 114 0m0 0h6m0 0a2 2 0 104 0m-4 0a2 2 0 114 0m0 0h2M3 6h18M3 18h18"/>`,
  // 06 Governance
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/>`,
  // 07 Web Dev
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>`,
  // 08 Automation
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>`,
  // 09 Email
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>`,
  // 10 Backup
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>`,
];
---

<section id="services" class="bg-cream py-24 lg:py-36">
  <div class="container mx-auto px-6 lg:px-16 xl:px-24">
    <!-- Section header -->
    <div class="max-w-3xl mb-16 lg:mb-24 fade-up">
      <div class="section-eyebrow mb-5">
        <div class="w-8 h-px bg-gold" aria-hidden="true"></div>
        {s.eyebrow}
      </div>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-navy mb-6 leading-tight">
        {s.headline}
      </h2>
      <p class="font-body text-navy/55 text-lg leading-relaxed">
        {s.subheadline}
      </p>
    </div>

    <!-- Services grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-px bg-navy/10">
      {
        s.items.map((item, i) => (
          <article
            class="fade-up bg-cream group relative flex flex-col p-8 lg:p-10 hover:bg-white transition-colors duration-300 overflow-hidden"
            style={`transition-delay: ${(i % 3) * 0.08}s`}
          >
            <!-- Gold left border on hover -->
            <div class="absolute left-0 top-0 bottom-0 w-0.5 bg-gold scale-y-0 group-hover:scale-y-100 transition-transform duration-400 origin-bottom" aria-hidden="true" />

            <!-- Number + Icon row -->
            <div class="flex items-start justify-between mb-6">
              <span class="font-display text-5xl font-bold text-navy/10 group-hover:text-gold/20 transition-colors duration-300 leading-none select-none">
                {item.number}
              </span>
              <div class="w-10 h-10 flex items-center justify-center border border-navy/15 group-hover:border-gold/50 transition-colors duration-300 flex-shrink-0">
                <svg
                  class="w-5 h-5 text-navy/40 group-hover:text-gold transition-colors duration-300"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  aria-hidden="true"
                  set:html={icons[i]}
                />
              </div>
            </div>

            <!-- Title -->
            <h3 class="font-display text-xl font-semibold text-navy mb-4 leading-snug group-hover:text-navy transition-colors">
              {item.title}
            </h3>

            <!-- Description -->
            <p class="font-body text-navy/55 text-sm leading-relaxed flex-grow mb-6">
              {item.description}
            </p>

            <!-- Tags -->
            <div class="flex flex-wrap gap-2 mt-auto">
              {item.tags.map((tag) => (
                <span class="font-body text-[11px] font-semibold tracking-wider uppercase text-navy/40 border border-navy/15 px-2.5 py-1 group-hover:border-gold/40 group-hover:text-gold/70 transition-colors duration-300">
                  {tag}
                </span>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
