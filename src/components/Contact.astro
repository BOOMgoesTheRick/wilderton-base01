---
import type { Translations } from '../i18n/types';
import type { Locale } from '../i18n/utils';

interface Props {
  t: Translations;
  locale?: Locale;
}

const { t } = Astro.props;
const c = t.contact;
const f = c.form;
---

<section class="sec" id="contact" style="border-bottom:0">
  <div class="wrap">
    <div class="sec-head reveal">
      <div class="sec-tag">{c.eyebrow}</div>
      <div>
        <h2 class="sec-title">{c.headline}</h2>
        <p class="sec-sub">{c.subheadline}</p>
      </div>
    </div>

    <div class="contact-grid">
      <div class="contact-info reveal">
        <div class="contact-item">
          <div class="lab">Email</div>
          <div class="val"><a href="mailto:info@wilderton.ca">info@wilderton.ca</a></div>
        </div>
        <div class="contact-item">
          <div class="lab">Location</div>
          <div class="val">Québec, Canada</div>
        </div>
        <div class="contact-item">
          <div class="lab">Response Window</div>
          <div class="val">Within 24 hours</div>
        </div>
        <div class="contact-item">
          <div class="lab">Confidentiality</div>
          <div class="val" style="font-size:13px;color:var(--body-text-2);letter-spacing:0">
            {f.disclaimer}
          </div>
        </div>
      </div>

      <form
        class="reveal"
        id="contact-form"
        onsubmit="event.preventDefault();document.getElementById('sent').style.display='flex';this.reset();"
      >
        <div class="field">
          <label for="f-name">{f.name}</label>
          <input id="f-name" type="text" required />
        </div>
        <div class="field">
          <label for="f-org">{f.org}</label>
          <input id="f-org" type="text" />
        </div>
        <div class="field">
          <label for="f-email">{f.email}</label>
          <input id="f-email" type="email" required />
        </div>
        <div class="field">
          <label for="f-subject">{f.subject}</label>
          <input id="f-subject" type="text" />
        </div>
        <div class="field row-wide">
          <label for="f-msg">{f.message}</label>
          <textarea id="f-msg" required></textarea>
        </div>
        <div class="send-row">
          <span class="note">Encrypted in transit · Stored 30 days max.</span>
          <button class="btn" type="submit">{f.submit} <span class="arr">→</span></button>
        </div>
        <div
          id="sent"
          style="display:none;grid-column:span 2;border:1px solid var(--fg);padding:14px;align-items:center;gap:10px;font-size:13px"
        >
          <span style="display:inline-block;width:8px;height:8px;background:var(--accent);border-radius:50%"></span>
          Message sent successfully. I will be in touch shortly.
        </div>
      </form>
    </div>
  </div>
</section>
