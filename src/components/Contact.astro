---
import type { Translations } from '../i18n/types';
import type { Locale } from '../i18n/utils';

interface Props {
  t: Translations;
  locale?: Locale;
}

const { t } = Astro.props;
const c = t.contact;
const f = c.form;
---

<section class="sec" id="contact" style="border-bottom:0">
  <div class="wrap">
    <div class="sec-head reveal">
      <div class="sec-tag">{c.eyebrow}</div>
      <div>
        <h2 class="sec-title">{c.headline}</h2>
        <p class="sec-sub">{c.subheadline}</p>
      </div>
    </div>

    <div class="contact-grid">
      <div class="contact-info reveal">
        <div class="contact-item">
          <div class="lab">Email</div>
          <div class="val"><a href="mailto:info@wilderton.ca">info@wilderton.ca</a></div>
        </div>
        <div class="contact-item">
          <div class="lab">Location</div>
          <div class="val">Québec, Canada</div>
        </div>
        <div class="contact-item">
          <div class="lab">Response Window</div>
          <div class="val">Within 24 hours</div>
        </div>
        <div class="contact-item">
          <div class="lab">Confidentiality</div>
          <div class="val" style="font-size:13px;color:var(--body-text-2);letter-spacing:0">
            {f.disclaimer}
          </div>
        </div>
      </div>

      <form class="reveal" id="contact-form">
        <div class="field">
          <label for="f-name">{f.name}</label>
          <input id="f-name" name="name" type="text" required autocomplete="name" />
        </div>
        <div class="field">
          <label for="f-org">{f.org}</label>
          <input id="f-org" name="org" type="text" autocomplete="organization" />
        </div>
        <div class="field">
          <label for="f-email">{f.email}</label>
          <input id="f-email" name="email" type="email" required autocomplete="email" />
        </div>
        <div class="field">
          <label for="f-subject">{f.subject}</label>
          <input id="f-subject" name="subject" type="text" />
        </div>
        <div class="field row-wide">
          <label for="f-msg">{f.message}</label>
          <textarea id="f-msg" name="message" required></textarea>
        </div>
        <div class="send-row">
          <span class="note">Encrypted in transit · Stored 30 days max.</span>
          <button class="btn" type="submit" id="contact-submit">
            {f.submit} <span class="arr">→</span>
          </button>
        </div>
        <div id="contact-sent" style="display:none;grid-column:span 2;border:1px solid var(--fg);padding:14px;align-items:center;gap:10px;font-size:13px">
          <span style="display:inline-block;width:8px;height:8px;background:var(--accent);border-radius:50%"></span>
          Message sent successfully. I will be in touch shortly.
        </div>
        <div id="contact-error" style="display:none;grid-column:span 2;border:1px solid #c0392b;padding:14px;font-size:13px;color:#c0392b">
          Something went wrong. Please try again or email directly at info@wilderton.ca
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const btn  = document.getElementById('contact-submit') as HTMLButtonElement | null;
  const sent = document.getElementById('contact-sent') as HTMLElement | null;
  const err  = document.getElementById('contact-error') as HTMLElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!btn) return;

    btn.disabled = true;
    btn.textContent = 'Sending…';
    if (sent) sent.style.display = 'none';
    if (err)  err.style.display  = 'none';

    const data = Object.fromEntries(new FormData(form));

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        if (sent) sent.style.display = 'flex';
        form.reset();
      } else {
        if (err) err.style.display = 'block';
      }
    } catch {
      if (err) err.style.display = 'block';
    } finally {
      btn.disabled = false;
      btn.innerHTML = 'Send Message <span class="arr">→</span>';
    }
  });
</script>
