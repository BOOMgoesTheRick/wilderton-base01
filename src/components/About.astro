---
import type { Translations } from '../i18n/types';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const a = t.about;
---

<section class="sec" id="about">
  <div class="wrap">
    <div class="sec-head reveal">
      <div class="sec-tag">{a.eyebrow}</div>
      <div>
        <h2 class="sec-title" style="white-space:pre-line">{a.headline}</h2>
      </div>
    </div>

    <div class="about-grid">
      <div class="about-body reveal">
        <p>{a.body}</p>
        <p>{a.body2}</p>
        <div class="signature">
          <div class="sig-mark" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:100%;height:100%;display:block">
              <polygon points="12,2 22,7 22,17 12,22 2,17 2,7"></polygon>
              <polygon points="12,5 19,8.5 19,15.5 12,19 5,15.5 5,8.5" fill="currentColor" stroke="none" style="fill:var(--accent)"></polygon>
            </svg>
          </div>
          <div class="sig-meta">
            <b>Eric B.</b>
            <span>{a.signature}</span>
          </div>
        </div>
      </div>

      <aside class="about-card reveal">
        <div class="hex-bg" aria-hidden="true"></div>
        <div class="about-card-head">
          <span>{a.card_title}</span>
          <span>2026</span>
        </div>
        <div class="about-card-row">
          <div class="about-stat">
            <div class="num">50+</div>
            <div class="lab">{a.stat_projects}</div>
          </div>
          <div class="about-stat">
            <div class="num">10</div>
            <div class="lab">{a.stat_domains}</div>
          </div>
        </div>
        <div class="ticker">
          <span>{a.status_label}</span><span><b id="liveStatus">{a.status_value}</b></span>
        </div>
        <div class="ticker">
          <span>{a.uptime_label}</span><span><b id="uptime">00:00:00</b></span>
        </div>
        <div class="ticker">
          <span>{a.response_label}</span><span><b>&lt; 24h</b></span>
        </div>
      </aside>
    </div>
  </div>
</section>

<script>
  // About card hex background
  (function () {
    const cardHost = document.querySelector('.about-card .hex-bg');
    if (!cardHost) return;

    const svgNS = 'http://www.w3.org/2000/svg';
    const s2 = 20;
    const w2 = Math.sqrt(3) * s2;
    const vs2 = 2 * s2 * 0.75;
    const W2 = 420, H2 = 320;
    const svg2 = document.createElementNS(svgNS, 'svg');
    svg2.setAttribute('viewBox', `0 0 ${W2} ${H2}`);

    function hexPath(cx: number, cy: number, r: number) {
      let d = '';
      for (let i = 0; i < 6; i++) {
        const a = (Math.PI / 3) * i + Math.PI / 6;
        const x = cx + r * Math.cos(a);
        const y = cy + r * Math.sin(a);
        d += (i === 0 ? 'M' : 'L') + x.toFixed(2) + ' ' + y.toFixed(2) + ' ';
      }
      return d + 'Z';
    }

    for (let r = 0; r < Math.ceil(H2 / vs2) + 2; r++) {
      for (let c = 0; c < Math.ceil(W2 / w2) + 2; c++) {
        const cx = c * w2 + (r % 2 ? w2 / 2 : 0);
        const cy = r * vs2;
        const p = document.createElementNS(svgNS, 'path');
        p.setAttribute('d', hexPath(cx, cy, s2 - 1.5));
        p.setAttribute('fill', 'none');
        p.setAttribute('stroke', 'currentColor');
        p.setAttribute('stroke-width', '0.6');
        svg2.appendChild(p);
      }
    }
    cardHost.appendChild(svg2);
  })();

  // Uptime ticker
  const start = performance.now();
  function pad(n: number) { return String(n).padStart(2, '0'); }
  setInterval(() => {
    const el = document.getElementById('uptime');
    if (!el) return;
    const s = Math.floor((performance.now() - start) / 1000);
    el.textContent = `${pad(Math.floor(s / 3600))}:${pad(Math.floor((s % 3600) / 60))}:${pad(s % 60)}`;
  }, 1000);
</script>
