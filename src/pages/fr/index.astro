---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import Services from '../../components/Services.astro';
import About from '../../components/About.astro';
import WhyUs from '../../components/WhyUs.astro';
import Questions from '../../components/Questions.astro';
import Portfolio from '../../components/Portfolio.astro';
import Diagnostic from '../../components/Diagnostic.astro';
import Contact from '../../components/Contact.astro';
import Footer from '../../components/Footer.astro';
import { getTranslations } from '../../i18n/utils';

const locale = 'fr';
const t = getTranslations(locale);
---

<Layout title={t.meta.title} description={t.meta.description} lang={locale}>
  <Header t={t} locale={locale} />
  <main>
    <Hero t={t} locale={locale} />
    <Services t={t} />
    <About t={t} />
    <WhyUs t={t} />
    <Questions t={t} />
    <Portfolio t={t} />
    <Diagnostic t={t} />
    <Contact t={t} />
  </main>
  <Footer t={t} locale={locale} />
</Layout>
